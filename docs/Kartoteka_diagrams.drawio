  <diagram id="tree" name="Структура каталогов">
    <mxGraphModel dx="1030" dy="634" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="900" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t_title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;" value="Структура каталогов" vertex="1">
          <mxGeometry height="30" width="400" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="proj_title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#555555;" value="Проект" vertex="1">
          <mxGeometry height="20" width="200" x="42" y="65" as="geometry" />
        </mxCell>
        <mxCell id="proj_tree" parent="1" style="text;html=1;whiteSpace=pre;align=left;verticalAlign=top;fontFamily=Courier New;fontSize=12;spacingLeft=10;spacingTop=8;fillColor=#f5f5f5;strokeColor=#cccccc;rounded=1;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;Kartoteka/&lt;br&gt;├── config/ — настройки Django, корневые urls, wsgi/asgi&lt;br&gt;├── common/ — общие утилиты (исключения, сортировка, сводки)&lt;br&gt;├── apps/ — доменные приложения&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── core/ — главная страница-хаб, теги сортировки&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── users/ — аутентификация (вход/регистрация/профиль, JWT)&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── owners/ — юр. лица (владельцы), иерархия владения&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── categories/ — справочник категорий объектов&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── objects/ — объекты производства и «система на объекте»&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── system/ — классы автоматизации, продукты, системы&lt;br&gt;│&amp;nbsp;&amp;nbsp; └── entities/ — участники рынка и профили типов&lt;br&gt;├── static/ — css / js&lt;br&gt;├── data/ — фикстуры (дампы данных)&lt;br&gt;└── docs/ — документация, схемы БД, выгрузки" vertex="1">
          <mxGeometry height="270" width="480" x="42" y="90" as="geometry" />
        </mxCell>
        <mxCell id="app_title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#555555;" value="Внутренняя структура доменного приложения (пример: objects)" vertex="1">
          <mxGeometry height="20" width="380" x="550" y="60" as="geometry" />
        </mxCell>
        <mxCell id="app_tree" parent="1" style="text;html=1;whiteSpace=pre;align=left;verticalAlign=top;fontFamily=Courier New;fontSize=12;spacingLeft=10;spacingTop=8;fillColor=#f5f5f5;strokeColor=#cccccc;rounded=1;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;apps/objects/&lt;br&gt;├── models.py — Object, ObjectSystem&lt;br&gt;├── admin.py — регистрация в админ-панели&lt;br&gt;├── apps.py — конфигурация приложения&lt;br&gt;├── urls.py — HTML-маршруты&lt;br&gt;├── views.py — HTML-представления&lt;br&gt;├── api/ — REST API&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── serializers.py&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── views.py&lt;br&gt;│&amp;nbsp;&amp;nbsp; └── urls.py&lt;br&gt;├── usecases/ — бизнес-логика&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── object_usecase.py&lt;br&gt;│&amp;nbsp;&amp;nbsp; ├── object_system_usecase.py&lt;br&gt;│&amp;nbsp;&amp;nbsp; └── validators.py&lt;br&gt;├── repositories/ — доступ к данным&lt;br&gt;├── templates/objects/ — HTML-шаблоны&lt;br&gt;├── migrations/ — миграции схемы БД&lt;br&gt;└── tests/ — тесты" vertex="1">
          <mxGeometry height="318" width="360" x="550" y="85" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
