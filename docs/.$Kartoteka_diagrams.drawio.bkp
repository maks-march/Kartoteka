        <mxCell id="legend" value="Синий — доменные сущности · Зелёный — участники/профили · Оранжевый — справочники · Фиолетовый — связь-таблица" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
