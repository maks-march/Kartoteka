        <mxCell id="re6" value="класс" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#d79b00;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="autosys" target="autoclass">
          <mxGeometry relative="1" as="geometry" />
