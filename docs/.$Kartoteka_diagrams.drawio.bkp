        <mxCell id="autoclass" value="AutomationClass&#10;(класс L0–L4, подсистемы)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="300" width="150" height="50" as="geometry" />
