        <mxCell id="entity" value="Entity&#10;(участник рынка)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1010" y="150" width="80" height="60" as="geometry" />
