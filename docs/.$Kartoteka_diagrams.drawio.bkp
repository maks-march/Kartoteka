          <mxGeometry x="40" y="380" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="entity2" value="Entity&#10;(исполнитель / поставщик)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="300" width="150" height="50" as="geometry" />
        </mxCell>

        <mxCell id="re1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=none;strokeColor=#9673a6;" edge="1" parent="1" source="object" target="objsys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=none;strokeColor=#9673a6;" edge="1" parent="1" source="objsys" target="autosys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re3" value="строится на" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#6c8ebf;fontSize=10;" edge="1" parent="1" source="autosys" target="product">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re4" value="автор" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;" edge="1" parent="1" source="product" target="vprofile">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re5" value="1:1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#82b366;fontSize=10;" edge="1" parent="1" source="vprofile" target="entity">
          <mxGeometry relative="1" as="geometry" />
